# ============================================================
# AI智能选股评估系统 · 环境变量配置模板
# ============================================================
# 使用方式：复制本文件为 .env，然后填入真实值
# 警告：.env 文件包含敏感信息，禁止提交到版本控制

# ── 1. QVeris API（必须）─────────────────────────────────
# 用于：指数实时行情、新闻情绪查询
# 获取方式：联系 QVeris 服务商申请 API Key
# 格式：sk-cn-xxxxxxxxxxxxxxxxxxxxxxxx
QVERIS_API_KEY=sk-cn-YOUR_KEY_HERE

# ── 2. 微信推送目标用户（必须）───────────────────────────
# 用于：微信推送日报和预警
# 格式：微信用户ID（类似 o9cq80_ToiULYpVvuMwnESzhnoCU@im.wechat）
WEIXIN_TARGET_USER=YOUR_WEIXIN_USER_ID

# ── 3. 飞书推送目标用户（可选，降级用）──────────────────
# 用于：微信推送失败时降级到飞书
# 格式：飞书 user ID（类似 user:02501203084326315375）
# 如不需要飞书降级，可留空
FEISHU_TARGET_USER=YOUR_FEISHU_USER_ID